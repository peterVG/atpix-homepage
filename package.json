{
  "name": "atpix-homepage",
  "private": true,
  "description": "Static marketing homepage for atpix.net",
  "scripts": {
    "vendor:assets": "bash ./scripts/vendor-assets.sh",
    "build:css": "tailwindcss -i ./src/input.css -o ./assets/css/main.css --minify",
    "build": "npm run build:css",
    "sync:status": "bash ./scripts/sync-status-from-atpix.sh"
  },
  "devDependencies": {
    "@fontsource/hanken-grotesk": "^5.2.5",
    "@fontsource/inter": "^5.2.5",
    "@fontsource/jetbrains-mono": "^5.2.5",
    "@tailwindcss/container-queries": "^0.1.1",
    "@tailwindcss/forms": "^0.5.10",
    "tailwindcss": "^3.4.17"
  }
}